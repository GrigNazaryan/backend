# PostgreSQL connection string.
# Local dev example (matches docker-compose.yml):
DATABASE_URL=postgresql://yerevan:yerevan@localhost:5432/yerevan_services

# Secret used to sign JWT session tokens. Generate a real random value for
# anything beyond local testing, e.g.: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_DAYS=30

# Allowed origins for CORS (comma separated). Not critical for a mobile
# app talking directly to this API, but harmless to leave permissive here.
CORS_ORIGINS=*

# --- Email provider (used for OTP sign-in codes) ---
# Which provider to use. Options: "console", "smtp".
# "console" just prints the code to the server log instead of sending a
# real email — use this for local development so you're not depending on
# real credentials while testing.
EMAIL_PROVIDER=console

# Only needed if EMAIL_PROVIDER=smtp (see README.md "Email integration" section)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=
